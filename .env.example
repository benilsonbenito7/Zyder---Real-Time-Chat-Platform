# PostgreSQL
POSTGRES_DB=example_db
POSTGRES_USER=example_user
POSTGRES_PASSWORD=example_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

#42 Auth
OAUTH_42_CLIENT_ID=your-42-client-id
OAUTH_42_CLIENT_SECRET=your-42-client-secret
OAUTH_42_REDIRECT_URI=https://localhost:8443/api/auth/42/callback/

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=https://localhost:8443/auth/github/callback

FRONTEND_URL=https://localhost:8443
REDIS_URL=redis://redis:6379

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://localhost:8443,https://localhost,https://127.0.0.1:8443,https://127.0.0.1

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
